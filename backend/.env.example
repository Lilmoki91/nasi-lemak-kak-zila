# ==============================================
# ZILA FOOD - ENVIRONMENT VARIABLES (TEMPLATE)
# ==============================================

# Gemini AI API Key
GEMINI_API_KEY=your_gemini_api_key_here

# ImgBB API Key (Untuk upload gambar)
IMGBB_API_KEY=your_imgbb_api_key_here

# Admin Authentication (SHA256 Hash)
ADMIN_PHONE_HASH=sha256$your_phone_hash_here
ADMIN_PASSWORD_HASH=sha256$your_password_hash_here

# Secret Key untuk session/token
SECRET_KEY=your_random_secret_key_here

# Firebase Service Account JSON (Satu baris, tanpa newline)
FIREBASE_CREDENTIALS={"type":"service_account", "project_id":"zila-food", ...}
