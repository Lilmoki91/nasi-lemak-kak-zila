# ==============================================
# ZILA FOOD - ROOT .gitignore
# ==============================================

# ==============================================
# ️ CLOUDFLARE / WRANGLER (ASAL)
# ==============================================
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example

# ==============================================
#  Environment variables (KUNCI RAHSIA)
# ==============================================
.env.local
.env.production
backend-main/.env
backend-ai/.env

# ==============================================
# 🔥 Firebase (JANGAN UPLOAD KEY)
# ==============================================
firebase-key.json
firebase-*.json
*service-account*.json
*credentials*.json

# ==============================================
# 🐍 Python
# ==============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/

# ==============================================
# 📁 Data sensitif
# ==============================================
owner_settings.json
*.sqlite3
*.db

# ==============================================
# 🔒 Admin auth (jangan upload folder auth)
# ==============================================
backend-main/admin_login/

# ==============================================
# ☁️ Render
# ==============================================
.rendertmp/

# ==============================================
# 💻 IDE
# ==============================================
.vscode/
.idea/
*.swp
*.swo
*~

# ==============================================
# 🖥️ OS
# ==============================================
.DS_Store
Thumbs.db
Desktop.ini

# ==============================================
# 📝 Logs
# ==============================================
*.log
logs/

# ==============================================
# 🧪 Testing
# ==============================================
.pytest_cache/
.coverage
htmlcov/

# ==============================================
# 🤖 Node modules (jika ada frontend build)
# ==============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==============================================
# 📦 Build output
# ==============================================
*.min.js
*.min.css
sourcemap
